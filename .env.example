# Copiar a .env y completar secretos. Ver src/common/envs.ts para el schema completo.
#
# Access JWT: debe coincidir con la cookie access_token (15 min).
# Si en .env local falta o está en "1m", usar "15m".
ACCESS_TOKEN_EXPIRES_IN=15m

# WhatsApp Cloud API (Meta Graph)
# WHATSAPP_ACCESS_TOKEN=tu_token_de_sistema_user
# PHONE_NUMBER_ID=tu_phone_number_id
# WHATSAPP_API_VERSION=v25.0
# WHATSAPP_TEMPLATE_NAME=jaspers_market_order_confirmation_v1
# WHATSAPP_TEMPLATE_LANGUAGE=en_US
