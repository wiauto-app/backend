{
  "info": {
    "_postman_id": "wiauto-api-collection",
    "name": "wiauto",
    "description": "Estructura: `wiauto` → `auth` | `vehicle`.\n\nVariables: `base_url`, `access_token` (JWT tras login), IDs de recurso, y para 2FA con `TwoFactorGuard` el body lleva `code` (6 dígitos) además del Bearer.\n\nRutas revisadas contra Nest (`auth`, `auth/me`, `2fa`, `users`).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" },
    { "key": "access_token", "value": "" },
    { "key": "vehicle_id", "value": "" },
    { "key": "feature_id", "value": "" },
    { "key": "vehicle_type_id", "value": "" },
    { "key": "color_id", "value": "" },
    { "key": "service_id", "value": "" },
    { "key": "dgt_label_id", "value": "" },
    { "key": "warranty_type_id", "value": "" },
    { "key": "traction_id", "value": "" }
  ],
  "item": [
    {
      "name": "wiauto",
      "item": [
        {
          "name": "auth",
          "item": [
            {
              "name": "Obtener sesión del usuario",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{access_token}}" }
                ],
                "url": "{{base_url}}/auth/me",
                "description": "`AuthGuard` (JWT)."
              }
            },
            {
              "name": "Iniciar sesión con google",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{base_url}}/auth/google",
                "description": "OAuth web: redirect. Callback: `GET /auth/google/callback`."
              }
            },
            {
              "name": "iniciar sesión con credenciales",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"usuario@ejemplo.com\",\n  \"password\": \"password12\"\n}"
                },
                "url": "{{base_url}}/auth/login",
                "description": "Respuesta: guarda el token en `access_token` (variable de colección)."
              }
            },
            {
              "name": "iniciar sesión google en mobile",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"id_token\": \"<google_id_token>\"\n}"
                },
                "url": "{{base_url}}/auth/google/mobile"
              }
            },
            {
              "name": "Inicializar 2fa",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{access_token}}" }
                ],
                "url": "{{base_url}}/2fa/setup",
                "description": "Devuelve QR / otpauth. `AuthGuard`."
              }
            },
            {
              "name": "Activar por primera vez 2fa",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{access_token}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"code\": \"123456\"\n}"
                },
                "url": "{{base_url}}/2fa/activate",
                "description": "`AuthGuard` + `TwoFactorGuard`: `code` = TOTP actual (6 dígitos). Habilita 2FA y puede devolver backup codes."
              }
            },
            {
              "name": "disable 2fa",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{access_token}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"code\": \"123456\"\n}"
                },
                "url": "{{base_url}}/2fa/disable",
                "description": "`AuthGuard` + `TwoFactorGuard`."
              }
            },
            {
              "name": "eliminar dispositivo",
              "request": {
                "method": "DELETE",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{access_token}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"code\": \"123456\"\n}"
                },
                "url": "{{base_url}}/2fa/delete",
                "description": "`AuthGuard` + `TwoFactorGuard`. El guard lee `body.code`."
              }
            },
            {
              "name": "Activar 2fa",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{access_token}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{}"
                },
                "url": "{{base_url}}/2fa/enable",
                "description": "En código no tiene `AuthGuard` (usa `@GetUser()`): si falla, revisa el controlador. Habilita 2FA sin paso TOTP previo en servicio."
              }
            },
            {
              "name": "Validar código de verificación",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"usuario@ejemplo.com\",\n  \"code\": \"codigo-respaldo\"\n}"
                },
                "url": "{{base_url}}/2fa/validate-backup-code",
                "description": "Público (sin Bearer en el controlador). Código de recuperación + email."
              }
            },
            {
              "name": "Regenerar codigos de recuperacion",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{access_token}}" }
                ],
                "url": "{{base_url}}/2fa/regenerate-backup-codes",
                "description": "`AuthGuard`."
              }
            },
            {
              "name": "Crear Usuario",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"nuevo@ejemplo.com\",\n  \"password\": \"password12\",\n  \"name\": \"Nombre\",\n  \"last_name\": \"Apellido\"\n}"
                },
                "url": "{{base_url}}/users",
                "description": "`UserController` — registro. `name` / `last_name` opcionales."
              }
            },
            {
              "name": "cuenta — verificación y recuperación (referencia)",
              "item": [
                {
                  "name": "confirmar email (token del correo)",
                  "request": {
                    "method": "POST",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": {
                      "mode": "raw",
                      "raw": "{\n  \"token\": \"<token_del_link>\"\n}"
                    },
                    "url": "{{base_url}}/auth/email-verification/confirm"
                  }
                },
                {
                  "name": "reenviar correo de verificación",
                  "request": {
                    "method": "POST",
                    "header": [
                      { "key": "Authorization", "value": "Bearer {{access_token}}" },
                      { "key": "Content-Type", "value": "application/json" }
                    ],
                    "url": "{{base_url}}/auth/email-verification/resend",
                    "description": "Solo cuentas `local` no verificadas."
                  }
                },
                {
                  "name": "solicitar recuperación de contraseña",
                  "request": {
                    "method": "POST",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": {
                      "mode": "raw",
                      "raw": "{\n  \"email\": \"usuario@ejemplo.com\"\n}"
                    },
                    "url": "{{base_url}}/auth/password-recovery/request"
                  }
                },
                {
                  "name": "cambiar contraseña (token del correo)",
                  "request": {
                    "method": "POST",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": {
                      "mode": "raw",
                      "raw": "{\n  \"token\": \"<token>\",\n  \"password\": \"nuevaPass12\"\n}"
                    },
                    "url": "{{base_url}}/auth/password-recovery/change"
                  }
                }
              ]
            }
          ]
        },
        {
          "name": "vehicle",
          "item": [
            {
              "name": "v1",
              "item": [
                {
                  "name": "crear vehículo",
                  "request": {
                    "method": "POST",
                    "header": [],
                    "body": {
                      "mode": "formdata",
                      "formdata": [
                        { "key": "vehicle_type_id", "value": "{{vehicle_type_id}}", "type": "text", "description": "Obligatorio. UUID de tipo de vehículo (`v1/vehicle-types`)." },
                        { "key": "price", "value": "25000", "type": "text" },
                        { "key": "mileage", "value": "45000", "type": "text" },
                        { "key": "lat", "value": "-12.0464", "type": "text" },
                        { "key": "lng", "value": "-77.0428", "type": "text" },
                        { "key": "condition", "value": "used", "type": "text", "description": "new | used" },
                        { "key": "title", "value": "Toyota ejemplo venta", "type": "text" },
                        { "key": "description", "value": "Descripción del anuncio con al menos diez caracteres para pasar validación.", "type": "text" },
                        { "key": "version_id", "value": "1", "type": "text", "description": "ID numérico de versión del catálogo (`v1/catalog/...`)." },
                        { "key": "phone_code", "value": "+51", "type": "text" },
                        { "key": "phone", "value": "999999999", "type": "text" },
                        { "key": "email", "value": "vendedor@ejemplo.com", "type": "text" },
                        { "key": "publisher_type", "value": "professional", "type": "text", "description": "professional | particular" },
                        { "key": "transmission_type", "value": "automatic", "type": "text", "description": "Opcional. manual | automatic. Si no envías el campo, el backend usa manual." },
                        { "key": "traction_id", "value": "{{traction_id}}", "type": "text", "description": "Obligatorio. UUID de catálogo tractions." },
                        { "key": "power", "value": "150", "type": "text" },
                        { "key": "displacement", "value": "2000", "type": "text", "description": "Opcional en el DTO; térmico suele exigir cilindrada > 0 por reglas de negocio." },
                        { "key": "autonomy", "value": "0", "type": "text", "disabled": true, "description": "Opcional. Relevante si el combustible del catálogo admite carga (eléctrico/híbrido enchufable)." },
                        { "key": "battery_capacity", "value": "0", "type": "text", "disabled": true, "description": "Opcional. Mismo criterio que autonomy." },
                        { "key": "time_to_charge", "value": "0", "type": "text", "disabled": true, "description": "Opcional. Mismo criterio que autonomy." },
                        { "key": "license_plate", "value": "ABC12", "type": "text", "disabled": true, "description": "Opcional. Mín. 5 caracteres si se envía." },
                        { "key": "features_ids", "value": "[]", "type": "text", "disabled": true, "description": "Opcional. Array JSON de UUIDs si tu pipe lo transforma; si no, envía repetidos features_ids o revisa transform en Nest." },
                        { "key": "services_ids", "value": "[]", "type": "text", "disabled": true, "description": "Opcional. JSON array de UUIDs de servicios." },
                        { "key": "color_id", "value": "{{color_id}}", "type": "text", "disabled": true, "description": "Opcional. UUID o vacío para no enviar." },
                        { "key": "dgt_label_id", "value": "{{dgt_label_id}}", "type": "text", "disabled": true },
                        { "key": "warranty_type_id", "value": "{{warranty_type_id}}", "type": "text", "disabled": true },
                        { "key": "files", "type": "file", "src": [] }
                      ]
                    },
                    "url": "{{base_url}}/v1/vehicles",
                    "description": "Multipart `form-data`: campos en snake_case alineados con `CreateVehicleHttpDto`. Obligatorios: vehicle_type_id, price, mileage, lat, lng, condition (new|used), title, description (min 10), version_id, phone_code, phone, email, publisher_type, traction_id, power. Opcionales: transmission_type (default manual), displacement, autonomy, battery_capacity, time_to_charge, license_plate, features_ids, services_ids, color_id, dgt_label_id, warranty_type_id. Incluye `files` (imágenes)."
                  }
                },
                {
                  "name": "obtener todos los vehículos",
                  "request": {
                    "method": "GET",
                    "header": [],
                    "url": "{{base_url}}/v1/vehicles?page=1&limit=20"
                  }
                },
                {
                  "name": "obtener vehículo por id",
                  "request": {
                    "method": "GET",
                    "header": [],
                    "url": "{{base_url}}/v1/vehicles/{{vehicle_id}}"
                  }
                },
                {
                  "name": "actualizar vehículo",
                  "request": {
                    "method": "PATCH",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": {
                      "mode": "raw",
                      "raw": "{\n  \"price\": 26000,\n  \"mileage\": 46000,\n  \"lat\": -12.0464,\n  \"lng\": -77.0428,\n  \"condition\": \"used\",\n  \"title\": \"Título actualizado mínimo cinco chars\",\n  \"features_ids\": [],\n  \"services_ids\": [],\n  \"vehicle_type_id\": null,\n  \"color_id\": null,\n  \"dgt_label_id\": null,\n  \"warranty_type_id\": null\n}"
                    },
                    "url": "{{base_url}}/v1/vehicles/{{vehicle_id}}",
                    "description": "Incluye opcionales: `features_ids`, `services_ids`, FKs de catálogo (`vehicle_type_id`, `color_id`, `dgt_label_id`, `warranty_type_id`). Usa `null` en un FK para quitar la relación."
                  }
                },
                {
                  "name": "eliminar vehículo",
                  "request": {
                    "method": "DELETE",
                    "header": [],
                    "url": "{{base_url}}/v1/vehicles/{{vehicle_id}}",
                    "description": "Borra el vehículo; antes elimina los objetos de imágenes en MinIO asociados a `vehicle_images`. Variable de colección: `vehicle_id` (UUID)."
                  }
                }
              ]
            },
            {
              "name": "vehicle-images",
              "item": [
                {
                  "name": "subir imagen (una)",
                  "request": {
                    "method": "POST",
                    "header": [],
                    "body": {
                      "mode": "formdata",
                      "formdata": [{ "key": "file", "type": "file", "src": [] }]
                    },
                    "url": "{{base_url}}/v1/vehicle-images/upload/{{vehicle_id}}"
                  }
                },
                {
                  "name": "subir imágenes (bulk)",
                  "request": {
                    "method": "POST",
                    "header": [],
                    "body": {
                      "mode": "formdata",
                      "formdata": [{ "key": "files", "type": "file", "src": [] }]
                    },
                    "url": "{{base_url}}/v1/vehicle-images/bulk/{{vehicle_id}}"
                  }
                }
              ]
            },
            {
              "name": "vehicle-videos",
              "item": [
                {
                  "name": "generar URL firmada (upload vídeo)",
                  "request": {
                    "method": "POST",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": {
                      "mode": "raw",
                      "raw": "{\n  \"file_key\": \"videos/ejemplo/clave.mp4\",\n  \"content_type\": \"video/mp4\"\n}"
                    },
                    "url": "{{base_url}}/v1/generate-video-signed-url",
                    "description": "`content_type`: image/jpeg, video/mp4, etc. (ver CONTENT_TYPES en backend)."
                  }
                },
                {
                  "name": "confirmar subida de vídeo",
                  "request": {
                    "method": "POST",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": {
                      "mode": "raw",
                      "raw": "{\n  \"file_key\": \"videos/ejemplo/clave.mp4\"\n}"
                    },
                    "url": "{{base_url}}/v1/confirm-video-upload"
                  }
                }
              ]
            },
            {
              "name": "caracteristicas",
              "item": [
                {
                  "name": "crear característica",
                  "request": {
                    "method": "POST",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": {
                      "mode": "raw",
                      "raw": "{\n  \"name\": \"Aire acondicionado\"\n}"
                    },
                    "url": "{{base_url}}/v1/features",
                    "description": "Respuesta incluye `slug` generado a partir de `name` (slugify: minúsculas, guiones)."
                  }
                },
                {
                  "name": "obtener todas las características",
                  "request": {
                    "method": "GET",
                    "header": [],
                    "url": "{{base_url}}/v1/features?page=1&limit=20"
                  }
                },
                {
                  "name": "obtener característica por id",
                  "request": {
                    "method": "GET",
                    "header": [],
                    "url": "{{base_url}}/v1/features/{{feature_id}}"
                  }
                },
                {
                  "name": "actualizar característica",
                  "request": {
                    "method": "PATCH",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": {
                      "mode": "raw",
                      "raw": "{\n  \"id\": \"{{feature_id}}\",\n  \"name\": \"Nombre actualizado\"\n}"
                    },
                    "url": "{{base_url}}/v1/features",
                    "description": "El id va en el body, no en la URL. Respuesta: `{ \"feature\": { \"id\", \"name\", \"slug\", ... } }`; el `slug` se recalcula al cambiar el nombre."
                  }
                },
                {
                  "name": "eliminar característica",
                  "request": {
                    "method": "DELETE",
                    "header": [],
                    "url": "{{base_url}}/v1/features/{{feature_id}}"
                  }
                }
              ]
            },
            {
              "name": "vehicle-types",
              "item": [
                {
                  "name": "crear tipo de vehículo",
                  "request": {
                    "method": "POST",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": {
                      "mode": "raw",
                      "raw": "{\n  \"name\": \"SUV\"\n}"
                    },
                    "url": "{{base_url}}/v1/vehicle-types"
                  }
                },
                {
                  "name": "obtener todos los tipos",
                  "request": {
                    "method": "GET",
                    "header": [],
                    "url": "{{base_url}}/v1/vehicle-types"
                  }
                },
                {
                  "name": "obtener tipo por id",
                  "request": {
                    "method": "GET",
                    "header": [],
                    "url": "{{base_url}}/v1/vehicle-types/{{vehicle_type_id}}"
                  }
                },
                {
                  "name": "actualizar tipo de vehículo",
                  "request": {
                    "method": "PATCH",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": {
                      "mode": "raw",
                      "raw": "{\n  \"name\": \"SUV premium\"\n}"
                    },
                    "url": "{{base_url}}/v1/vehicle-types/{{vehicle_type_id}}"
                  }
                },
                {
                  "name": "eliminar tipo de vehículo",
                  "request": {
                    "method": "DELETE",
                    "header": [],
                    "url": "{{base_url}}/v1/vehicle-types/{{vehicle_type_id}}"
                  }
                }
              ]
            },
            {
              "name": "servicios",
              "item": [
                {
                  "name": "crear servicio",
                  "request": {
                    "method": "POST",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": {
                      "mode": "raw",
                      "raw": "{\n  \"name\": \"Financiamiento\",\n  \"description\": \"Opciones de crédito y cuotas\"\n}"
                    },
                    "url": "{{base_url}}/v1/services",
                    "description": "Respuesta: `{ \"service\": { \"id\", \"name\", \"description\", \"slug\", ... } }`. El `slug` se genera desde `name`."
                  }
                },
                {
                  "name": "obtener todos los servicios",
                  "request": {
                    "method": "GET",
                    "header": [],
                    "url": "{{base_url}}/v1/services"
                  }
                },
                {
                  "name": "obtener servicio por id",
                  "request": {
                    "method": "GET",
                    "header": [],
                    "url": "{{base_url}}/v1/services/{{service_id}}"
                  }
                },
                {
                  "name": "actualizar servicio",
                  "request": {
                    "method": "PATCH",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": {
                      "mode": "raw",
                      "raw": "{\n  \"name\": \"Financiamiento premium\",\n  \"description\": \"Crédito directo y tasas preferentes\"\n}"
                    },
                    "url": "{{base_url}}/v1/services/{{service_id}}",
                    "description": "Campos opcionales. Si cambias `name`, se recalcula `slug`."
                  }
                },
                {
                  "name": "eliminar servicio",
                  "request": {
                    "method": "DELETE",
                    "header": [],
                    "url": "{{base_url}}/v1/services/{{service_id}}"
                  }
                }
              ]
            },
            {
              "name": "etiquetas DGT",
              "item": [
                {
                  "name": "crear etiqueta DGT",
                  "request": {
                    "method": "POST",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": {
                      "mode": "raw",
                      "raw": "{\n  \"name\": \"Etiqueta 0 emisiones\",\n  \"code\": \"0\",\n  \"description\": \"Vehículos de cero emisiones (eléctrico de batería, pila de combustible, etc.) según criterios DGT.\"\n}"
                    },
                    "url": "{{base_url}}/v1/dgt-labels",
                    "description": "Distintivo ambiental. `code`: 0, ECO, C o B (se guarda en mayúsculas). `slug` se genera desde `name`."
                  }
                },
                {
                  "name": "listar etiquetas DGT",
                  "request": {
                    "method": "GET",
                    "header": [],
                    "url": "{{base_url}}/v1/dgt-labels"
                  }
                },
                {
                  "name": "obtener etiqueta DGT por id",
                  "request": {
                    "method": "GET",
                    "header": [],
                    "url": "{{base_url}}/v1/dgt-labels/{{dgt_label_id}}"
                  }
                },
                {
                  "name": "actualizar etiqueta DGT",
                  "request": {
                    "method": "PATCH",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": {
                      "mode": "raw",
                      "raw": "{\n  \"description\": \"Texto actualizado de la etiqueta.\"\n}"
                    },
                    "url": "{{base_url}}/v1/dgt-labels/{{dgt_label_id}}",
                    "description": "Campos opcionales. Si cambias `name`, se recalcula `slug`; `code` se normaliza a mayúsculas."
                  }
                },
                {
                  "name": "eliminar etiqueta DGT",
                  "request": {
                    "method": "DELETE",
                    "header": [],
                    "url": "{{base_url}}/v1/dgt-labels/{{dgt_label_id}}"
                  }
                }
              ]
            },
            {
              "name": "tipos de garantía",
              "item": [
                {
                  "name": "crear tipo de garantía",
                  "request": {
                    "method": "POST",
                    "header": [{ "key": "Content-Type", "value": "application/json" }],
                    "body": {
                      "mode": "raw",
                      "raw": "{\n  \"name\": \"Garantía oficial fabricante\",\n  \"description\": \"Cobertura según condiciones del fabricante o concesionario autorizado.\"\n}"
